@page
@using EQToolApis.Services
@model EQToolApis.Pages.CharactersModel

<style>
    html, body { background: #0b0e1a; margin: 0; padding: 0; }

    .pg-wrap {
        max-width: 1100px;
        margin: 0 auto;
        padding: 28px 18px 40px 18px;
        font-family: 'Segoe UI', Arial, sans-serif;
        color: #cdd3e6;
        font-size: 14px;
    }

    .pg-topbar { margin-bottom: 22px; }
    .pg-topbar:after { content: ""; display: block; clear: both; }
    .pg-title { float: left; font-size: 26px; font-weight: bold; color: #ffffff; margin: 0; }
    .pg-sub { clear: left; color: #6b7390; font-size: 13px; margin-top: 4px; }
    .pg-user { float: right; text-align: right; color: #6b7390; font-size: 13px; }
    .pg-user a {
        display: inline-block;
        color: #9aa3c0;
        text-decoration: none;
        border: 1px solid #242c49;
        border-radius: 6px;
        padding: 4px 12px;
        margin-left: 10px;
        background: #131829;
    }
    .pg-user a:hover { color: #ffffff; border-color: #3c4670; }

    .pg-panel { background: #131829; border: 1px solid #242c49; border-radius: 10px; overflow: hidden; }
    .pg-table { width: 100%; border-collapse: collapse; }
    .pg-table th {
        text-align: left;
        color: #8b93b8;
        font-size: 11px;
        text-transform: uppercase;
        letter-spacing: 1px;
        padding: 12px 16px;
        border-bottom: 1px solid #242c49;
    }
    .pg-table td { padding: 12px 16px; border-bottom: 1px solid #1b2138; color: #dfe4f5; }
    .pg-table tr:last-child td { border-bottom: none; }
    .pg-table .num { text-align: right; }
    .character-row { cursor: pointer; }
    .character-row:hover td { background: #1a2138; }
    .character-row .pg-charname { color: #ffffff; font-weight: bold; }
    .pg-table .server-green { color: #4ade80; font-weight: bold; }
    .pg-table .server-blue { color: #60a5fa; font-weight: bold; }
    .pg-table .server-red { color: #f87171; font-weight: bold; }
    .pg-table .server-quarm { color: #c084fc; font-weight: bold; }

    .pg-empty { padding: 40px 20px; text-align: center; color: #9aa3c0; }

    #char-profile { display: none; }
    .pg-back {
        display: inline-block;
        color: #9aa3c0;
        text-decoration: none;
        margin-bottom: 14px;
        cursor: pointer;
        font-size: 13px;
    }
    .pg-back:hover { color: #ffffff; text-decoration: none; }

    @Html.Raw(CharacterProfileHtml.Css)
</style>

<div class="pg-wrap">
    <div class="pg-topbar">
        @if (Model.DiscordUsername != null)
        {
            <div class="pg-user">
                <span>@Model.DiscordUsername</span>
                <a href="/AllItems">All Items</a>
                <a href="/Account/Logout">Logout</a>
            </div>
        }
        <h1 class="pg-title">My Characters</h1>
        <div class="pg-sub">Characters with uploaded inventories. Click a character to view their gear.</div>
    </div>

    <div id="char-list">
        @if (!Model.Characters.Any())
        {
            <div class="pg-panel">
                <div class="pg-empty">No characters found. Upload your inventory from the Pigparse desktop app to see your characters here.</div>
            </div>
        }
        else
        {
            <div class="pg-panel">
                <table class="pg-table">
                    <thead>
                        <tr>
                            <th>Character</th>
                            <th>Server</th>
                            <th class="num">Items</th>
                            <th class="num">Last Updated</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var character in Model.Characters)
                        {
                            <tr class="character-row" data-character="@character.CharacterName" data-server="@character.Server">
                                <td class="pg-charname">@character.CharacterName</td>
                                <td class="server-@character.Server.ToString().ToLower()">@character.Server</td>
                                <td class="num">@character.ItemCount</td>
                                <td class="num mytime" utc="@character.UpdatedAt.ToString("o")">@character.UpdatedAt.ToString("u")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>

    <div id="char-profile">
        <a class="pg-back" id="back-link">&larr; All characters</a>
        <div id="pp-container"></div>
    </div>
</div>

<script>
    @Html.Raw(CharacterProfileHtml.Js)
</script>
<script>
    document.querySelectorAll('.mytime').forEach(function (el) {
        var d = new Date(el.getAttribute('utc'));
        el.textContent = d.toLocaleString();
    });

    var listEl = document.getElementById('char-list');
    var profileEl = document.getElementById('char-profile');
    var containerEl = document.getElementById('pp-container');

    document.querySelectorAll('.character-row').forEach(function (row) {
        row.addEventListener('click', function () {
            var name = this.dataset.character;
            var server = this.dataset.server;
            fetch('/Characters?handler=ProfileHtml&character=' + encodeURIComponent(name) + '&server=' + encodeURIComponent(server))
                .then(function (r) { return r.text(); })
                .then(function (html) {
                    containerEl.innerHTML = html;
                    listEl.style.display = 'none';
                    profileEl.style.display = 'block';
                    window.scrollTo(0, 0);
                });
        });
    });

    document.getElementById('back-link').addEventListener('click', function () {
        profileEl.style.display = 'none';
        listEl.style.display = 'block';
        containerEl.innerHTML = '';
        var tip = document.getElementById('pp-tooltip');
        if (tip) { tip.style.display = 'none'; }
    });
</script>
