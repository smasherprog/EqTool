<UserControl x:Class="EQTool.UI.SettingsComponents.SettingsTrigger"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:EQTool.UI.SettingsComponents"
             xmlns:models="clr-namespace:EQTool.Models"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="600">

    <UserControl.Resources>
        <local:StringToBrushConverter x:Key="StringToBrush"/>
        <Style x:Key="NumberBox" TargetType="TextBox">
            <Style.Triggers>
                <Trigger Property="Validation.HasError" Value="True">
                    <Setter Property="ToolTip"
                            Value="{Binding RelativeSource={RelativeSource Self}, Path=(Validation.Errors)/ErrorContent}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="White">
        <StackPanel Orientation="Vertical" Margin="6" Validation.Error="OnValidationError">

            <GroupBox Header="General Settings">
                <Grid Margin="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Trigger Name" VerticalAlignment="Center" Margin="0,2,8,2"/>
                    <TextBox Grid.Row="0" Grid.Column="1" Margin="0,2,0,2"
                             BorderBrush="{Binding TriggerNameBorderBrush}"
                             Text="{Binding TriggerName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" Foreground="Red"
                               Visibility="{Binding TriggerNameErrorMessgeVisible}" Text="{Binding TriggerNameErrorMessge}"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Search Text" VerticalAlignment="Center" Margin="0,2,8,2"/>
                    <TextBox Grid.Row="2" Grid.Column="1" Margin="0,2,0,2"
                             BorderBrush="{Binding SearchTextBorderBrush}"
                             Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    <TextBlock Grid.Row="3" Grid.Column="1" Foreground="Red"
                               Visibility="{Binding SearchTextErrorMessgeVisible}" Text="{Binding SearchTextErrorMessge}"/>

                    <StackPanel Grid.Row="4" Grid.Column="1" Orientation="Horizontal" Margin="0,2,0,2">
                        <CheckBox Content="Use Regular Expressions" VerticalAlignment="Center" Margin="0,0,16,0"
                                  IsChecked="{Binding UseRegex, Mode=TwoWay}"/>
                        <CheckBox Content="Use Fast Check" VerticalAlignment="Center"
                                  IsEnabled="{Binding CanUseFastCheck}"
                                  IsChecked="{Binding UseFastCheck, Mode=TwoWay}"/>
                        <CheckBox Content="Trigger Enabled" VerticalAlignment="Center" Margin="16,0,0,0"
                                  IsChecked="{Binding TriggerEnabled, Mode=TwoWay}"/>
                    </StackPanel>

                    <TextBlock Grid.Row="5" Grid.Column="0" Text="Category" VerticalAlignment="Center" Margin="0,2,8,2"/>
                    <ComboBox Grid.Row="5" Grid.Column="1" Margin="0,2,0,2" HorizontalAlignment="Left" MinWidth="140"
                              IsEditable="True"
                              ItemsSource="{Binding Categories}"
                              Text="{Binding Category, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Grid.Row="6" Grid.Column="0" Text="Comments" VerticalAlignment="Top" Margin="0,4,8,2"/>
                    <TextBox Grid.Row="6" Grid.Column="1" Margin="0,2,0,2" MinHeight="50"
                             TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"
                             Text="{Binding Comments, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                </Grid>
            </GroupBox>

            <TabControl Margin="0,6,0,0" MinHeight="320">
                <!-- Basic -->
                <TabItem Header="Basic">
                    <local:TriggerOutputEditor DataContext="{Binding Basic}" Margin="4"/>
                </TabItem>

                <!-- Timer -->
                <TabItem Header="Timer">
                    <Grid Margin="6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Timer Type" VerticalAlignment="Center" Margin="0,2,8,2"/>
                        <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Margin="0,2,0,2">
                            <ComboBox MinWidth="160" VerticalAlignment="Center"
                                      ItemsSource="{Binding TimerTypeOptions}"
                                      SelectedValuePath="Key" DisplayMemberPath="Value"
                                      SelectedValue="{Binding Timer.TimerType, Mode=TwoWay}"/>
                            <TextBlock Text="Bar Color" VerticalAlignment="Center" Margin="12,0,6,0"/>
                            <ComboBox Width="110" VerticalAlignment="Center"
                                      ItemsSource="{x:Static models:TriggerColors.Names}"
                                      SelectedItem="{Binding Timer.BarColor, Mode=TwoWay}"
                                      ToolTip="Timer bar color in the Triggers window">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <Border Width="12" Height="12" Margin="0,0,4,0" BorderBrush="Gray" BorderThickness="1"
                                                    Background="{Binding Converter={StaticResource StringToBrush}}"/>
                                            <TextBlock Text="{Binding}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                            <CheckBox Content="Show in overlay" VerticalAlignment="Center" Margin="12,0,0,0"
                                      IsChecked="{Binding Timer.ShowInOverlay, Mode=TwoWay}"/>
                        </StackPanel>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Timer Name" VerticalAlignment="Center" Margin="0,2,8,2"/>
                        <TextBox Grid.Row="1" Grid.Column="1" Margin="0,2,0,2"
                                 Text="{Binding Timer.TimerName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Timer Duration" VerticalAlignment="Center" Margin="0,2,8,2"/>
                        <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Margin="0,2,0,2">
                            <TextBox Width="40" Style="{StaticResource NumberBox}">
                                <TextBox.Text>
                                    <Binding Path="Timer.Hours" Mode="TwoWay" UpdateSourceTrigger="PropertyChanged" NotifyOnValidationError="True">
                                        <Binding.ValidationRules>
                                            <local:IntRangeRule Min="0" Max="999"/>
                                        </Binding.ValidationRules>
                                    </Binding>
                                </TextBox.Text>
                            </TextBox>
                            <TextBlock Text="h" Margin="2,0,8,0" VerticalAlignment="Center"/>
                            <TextBox Width="40" Style="{StaticResource NumberBox}">
                                <TextBox.Text>
                                    <Binding Path="Timer.Minutes" Mode="TwoWay" UpdateSourceTrigger="PropertyChanged" NotifyOnValidationError="True">
                                        <Binding.ValidationRules>
                                            <local:IntRangeRule Min="0" Max="59"/>
                                        </Binding.ValidationRules>
                                    </Binding>
                                </TextBox.Text>
                            </TextBox>
                            <TextBlock Text="m" Margin="2,0,8,0" VerticalAlignment="Center"/>
                            <TextBox Width="40" Style="{StaticResource NumberBox}">
                                <TextBox.Text>
                                    <Binding Path="Timer.Seconds" Mode="TwoWay" UpdateSourceTrigger="PropertyChanged" NotifyOnValidationError="True">
                                        <Binding.ValidationRules>
                                            <local:IntRangeRule Min="0" Max="59"/>
                                        </Binding.ValidationRules>
                                    </Binding>
                                </TextBox.Text>
                            </TextBox>
                            <TextBlock Text="s" Margin="2,0,8,0" VerticalAlignment="Center"/>
                        </StackPanel>

                        <TextBlock Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,6,0,2"
                                   Text="If timer is already running when triggered again:"/>
                        <ComboBox Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" HorizontalAlignment="Left" MinWidth="200" Margin="0,2,0,2"
                                  ItemsSource="{Binding RestartBehaviorOptions}"
                                  SelectedValuePath="Key" DisplayMemberPath="Value"
                                  SelectedValue="{Binding Timer.RestartBehavior, Mode=TwoWay}"/>

                        <StackPanel Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,8,0,0">
                            <TextBlock Text="End early text (for multiple possible values, add a row for each):" Margin="0,0,0,2"/>
                            <DataGrid ItemsSource="{Binding Timer.EndEarlyTexts}" AutoGenerateColumns="False"
                                      CanUserAddRows="True" CanUserDeleteRows="True" Height="140" HeadersVisibility="Column">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Search Text" Width="*"
                                                        Binding="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>
                                    <DataGridCheckBoxColumn Header="Use Regex"
                                                            Binding="{Binding UseRegex, UpdateSourceTrigger=PropertyChanged}"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Grid>
                </TabItem>

                <!-- Timer Ending -->
                <TabItem Header="Timer Ending">
                    <StackPanel Margin="6">
                        <StackPanel Orientation="Horizontal" Margin="0,2,0,2">
                            <CheckBox Content="Notify when timer is down to" VerticalAlignment="Center" Margin="0,0,8,0"
                                      IsChecked="{Binding TimerEnding.Enabled, Mode=TwoWay}"/>
                            <TextBox Width="40" Style="{StaticResource NumberBox}" IsEnabled="{Binding TimerEnding.Enabled}">
                                <TextBox.Text>
                                    <Binding Path="TimerEnding.Hours" Mode="TwoWay" UpdateSourceTrigger="PropertyChanged" NotifyOnValidationError="True">
                                        <Binding.ValidationRules>
                                            <local:IntRangeRule Min="0" Max="999"/>
                                        </Binding.ValidationRules>
                                    </Binding>
                                </TextBox.Text>
                            </TextBox>
                            <TextBlock Text="h" Margin="2,0,8,0" VerticalAlignment="Center"/>
                            <TextBox Width="40" Style="{StaticResource NumberBox}" IsEnabled="{Binding TimerEnding.Enabled}">
                                <TextBox.Text>
                                    <Binding Path="TimerEnding.Minutes" Mode="TwoWay" UpdateSourceTrigger="PropertyChanged" NotifyOnValidationError="True">
                                        <Binding.ValidationRules>
                                            <local:IntRangeRule Min="0" Max="59"/>
                                        </Binding.ValidationRules>
                                    </Binding>
                                </TextBox.Text>
                            </TextBox>
                            <TextBlock Text="m" Margin="2,0,8,0" VerticalAlignment="Center"/>
                            <TextBox Width="40" Style="{StaticResource NumberBox}" IsEnabled="{Binding TimerEnding.Enabled}">
                                <TextBox.Text>
                                    <Binding Path="TimerEnding.Seconds" Mode="TwoWay" UpdateSourceTrigger="PropertyChanged" NotifyOnValidationError="True">
                                        <Binding.ValidationRules>
                                            <local:IntRangeRule Min="0" Max="59"/>
                                        </Binding.ValidationRules>
                                    </Binding>
                                </TextBox.Text>
                            </TextBox>
                            <TextBlock Text="s" Margin="2,0,8,0" VerticalAlignment="Center"/>
                        </StackPanel>
                        <local:TriggerOutputEditor DataContext="{Binding TimerEnding.Output}" IsEnabled="{Binding TimerEnding.Enabled}"/>
                    </StackPanel>
                </TabItem>

                <!-- Timer Ended -->
                <TabItem Header="Timer Ended">
                    <StackPanel Margin="6">
                        <CheckBox Content="Notify when timer ends" Margin="0,2,0,2"
                                  IsChecked="{Binding TimerEnded.Enabled, Mode=TwoWay}"/>
                        <local:TriggerOutputEditor DataContext="{Binding TimerEnded.Output}" IsEnabled="{Binding TimerEnded.Enabled}"/>
                    </StackPanel>
                </TabItem>

                <!-- Counter -->
                <TabItem Header="Counter">
                    <StackPanel Orientation="Horizontal" Margin="6,8,6,6" VerticalAlignment="Top">
                        <CheckBox Content="Reset counter if unmatched for" VerticalAlignment="Center" Margin="0,0,8,0"
                                  IsChecked="{Binding Counter.ResetEnabled, Mode=TwoWay}"/>
                        <TextBox Width="40" VerticalAlignment="Center" Style="{StaticResource NumberBox}" IsEnabled="{Binding Counter.ResetEnabled}">
                            <TextBox.Text>
                                <Binding Path="Counter.Hours" Mode="TwoWay" UpdateSourceTrigger="PropertyChanged" NotifyOnValidationError="True">
                                    <Binding.ValidationRules>
                                        <local:IntRangeRule Min="0" Max="999"/>
                                    </Binding.ValidationRules>
                                </Binding>
                            </TextBox.Text>
                        </TextBox>
                        <TextBlock Text="h" Margin="2,0,8,0" VerticalAlignment="Center"/>
                        <TextBox Width="40" VerticalAlignment="Center" Style="{StaticResource NumberBox}" IsEnabled="{Binding Counter.ResetEnabled}">
                            <TextBox.Text>
                                <Binding Path="Counter.Minutes" Mode="TwoWay" UpdateSourceTrigger="PropertyChanged" NotifyOnValidationError="True">
                                    <Binding.ValidationRules>
                                        <local:IntRangeRule Min="0" Max="59"/>
                                    </Binding.ValidationRules>
                                </Binding>
                            </TextBox.Text>
                        </TextBox>
                        <TextBlock Text="m" Margin="2,0,8,0" VerticalAlignment="Center"/>
                        <TextBox Width="40" VerticalAlignment="Center" Style="{StaticResource NumberBox}" IsEnabled="{Binding Counter.ResetEnabled}">
                            <TextBox.Text>
                                <Binding Path="Counter.Seconds" Mode="TwoWay" UpdateSourceTrigger="PropertyChanged" NotifyOnValidationError="True">
                                    <Binding.ValidationRules>
                                        <local:IntRangeRule Min="0" Max="59"/>
                                    </Binding.ValidationRules>
                                </Binding>
                            </TextBox.Text>
                        </TextBox>
                        <TextBlock Text="s" Margin="2,0,8,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </TabItem>
            </TabControl>

            <GroupBox Header="Test" Margin="0,8,0,0">
                <StackPanel Orientation="Vertical" Margin="4">
                    <TextBlock Text="Paste a log line to test this trigger against:" Margin="0,0,0,2"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="TestLogLineText" Grid.Column="0" Margin="0,0,4,0"
                                 Text="" ToolTip="Enter or paste a single log line, then click Test."/>
                        <Button x:Name="TestButton" Grid.Column="1" Content="Test" Padding="14,2,14,2" Click="TestTrigger"/>
                    </Grid>
                    <TextBlock x:Name="TestResultText" Margin="0,4,0,0" FontWeight="Bold"/>
                </StackPanel>
            </GroupBox>

            <Button x:Name="SaveButton" HorizontalAlignment="Right" Margin="0,8,0,0" Padding="20,4,20,4"
                    Click="Save" Content="Save"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
