<UserControl x:Class="EQTool.UI.SettingsComponents.SettingsPlayer"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:EQTool.UI.SettingsComponents"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Background="#FF0B0E1A">
        <ScrollViewer x:Name="ProfileScroll"
                      Visibility="Collapsed"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="12">
            <Grid x:Name="ProfileHost">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
            </Grid>
        </ScrollViewer>
        <StackPanel x:Name="MessagePanel" VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="440" Margin="20">
            <TextBlock x:Name="MessageText"
                       TextWrapping="Wrap"
                       TextAlignment="Center"
                       Foreground="#FF9AA3C0"
                       FontSize="14"
                       LineHeight="22" />
            <Button x:Name="LoginButton"
                    Content="Login with Discord"
                    Visibility="Collapsed"
                    Click="LoginButton_Click"
                    Margin="0,20,0,0"
                    Padding="18,9"
                    HorizontalAlignment="Center"
                    Background="#FF5865F2"
                    Foreground="White"
                    BorderThickness="0"
                    FontWeight="Bold"
                    FontSize="13"
                    Cursor="Hand" />
        </StackPanel>
    </Grid>
</UserControl>
